---
import Layout from '../layouts/Layout.astro';
import { dietPlans } from '../data/dietPlans.js';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Diet Plans — NutriWorld" description="Explore 5 evidence-based diet plans with full nutrient breakdowns, benefits, and guidance on choosing the right eating pattern for you.">

  <!-- Hero -->
  <section class="section" style="background: linear-gradient(135deg, #F5F3EC 0%, #E8F5E9 100%); text-align: center; padding: 80px 20px;">
    <div class="container">
      <div style="font-size: 3rem; margin-bottom: 16px;">🥗</div>
      <h1 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; color: var(--text); margin-bottom: 16px; line-height: 1.2;">
        Diet Plans — Find Your<br><span style="color: var(--primary);">Perfect Eating Pattern</span>
      </h1>
      <p style="font-size: 1.15rem; color: var(--text-muted); max-width: 620px; margin: 0 auto 32px; line-height: 1.7;">
        Different dietary patterns have vastly different nutrient profiles, strengths, and gaps. We break down 5 evidence-based approaches so you can make an informed, sustainable choice.
      </p>
      <div style="display: flex; gap: 12px; flex-wrap: wrap; justify-content: center;">
        {dietPlans.map(plan => (
          <a href={`#${plan.id}`} style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 18px; background: white; border-radius: 40px; border: 2px solid var(--border); font-size: 0.9rem; font-weight: 600; color: var(--text); text-decoration: none; transition: all 0.2s;" onmouseover="this.style.borderColor=this.dataset.color; this.style.background=this.dataset.color+'18'" onmouseout="this.style.borderColor='var(--border)'; this.style.background='white'" data-color={plan.color}>
            {plan.emoji} {plan.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- No Perfect Diet callout -->
  <section class="section-alt" style="padding: 48px 20px;">
    <div class="container">
      <div class="highlight-box highlight-green" style="max-width: 820px; margin: 0 auto; border-radius: var(--radius); padding: 32px 40px;">
        <div style="display: flex; align-items: flex-start; gap: 20px; flex-wrap: wrap;">
          <div style="font-size: 2.5rem; flex-shrink: 0;">💡</div>
          <div>
            <h2 style="font-size: 1.4rem; font-weight: 700; color: var(--text); margin-bottom: 10px;">There Is No Single "Perfect" Diet</h2>
            <p style="color: var(--text-muted); line-height: 1.7; margin-bottom: 16px;">
              The best diet is the one you can sustain long-term while feeling great. Research consistently shows that adherence matters more than which specific plan you follow. Fortunately, all 5 plans on this page share a powerful common foundation:
            </p>
            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
              {['Emphasis on whole, minimally processed foods', 'Diverse vegetables and fruits', 'Legumes as a regular staple', 'Limiting ultra-processed foods', 'Healthy fats over refined fats', 'Adequate fiber (30g+ daily)'].map(point => (
                <span style="display: inline-flex; align-items: center; gap: 6px; background: white; padding: 6px 14px; border-radius: 20px; font-size: 0.875rem; color: var(--text); border: 1px solid rgba(46,204,113,0.3);">
                  <span style="color: var(--primary); font-weight: 700;">✓</span> {point}
                </span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Diet Plan Cards -->
  <section class="section" style="padding: 60px 20px;">
    <div class="container">
      <div style="display: flex; flex-direction: column; gap: 48px;">
        {dietPlans.map((plan, index) => (
          <div id={plan.id} class="card" style={`border-left: 6px solid ${plan.color}; border-radius: var(--radius); overflow: visible; scroll-margin-top: 80px;`}>

            <!-- Card Header -->
            <div style={`background: linear-gradient(135deg, ${plan.color}15 0%, ${plan.color}05 100%); padding: 28px 32px; border-radius: calc(var(--radius) - 6px) calc(var(--radius) - 0px) 0 0;`}>
              <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
                <div style="display: flex; align-items: center; gap: 16px;">
                  <div style={`width: 64px; height: 64px; border-radius: 16px; background: ${plan.color}25; display: flex; align-items: center; justify-content: center; font-size: 2rem; flex-shrink: 0;`}>
                    {plan.emoji}
                  </div>
                  <div>
                    <h2 style="font-size: 1.7rem; font-weight: 800; color: var(--text); margin: 0 0 4px;">{plan.name}</h2>
                    <p style="color: var(--text-muted); font-style: italic; margin: 0;">{plan.tagline}</p>
                  </div>
                </div>
                <div style="display: flex; align-items: center; gap: 8px; flex-shrink: 0;">
                  <span style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">Science Score</span>
                  <div style="display: flex; gap: 2px;">
                    {Array.from({length: 5}, (_, i) => (
                      <span style={`font-size: 1.1rem; ${i < plan.scienceScore ? 'opacity: 1' : 'opacity: 0.2'}`}>⭐</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>

            <!-- Card Body -->
            <div class="card-body" style="padding: 32px;">

              <!-- Description -->
              <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.7; margin-bottom: 28px; max-width: 800px;">
                {plan.description}
              </p>

              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 28px; margin-bottom: 28px;">

                <!-- Key Foods -->
                <div>
                  <h3 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 12px;">Key Foods</h3>
                  <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    {plan.keyFoods.map((food, i) => (
                      <span style={`display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; background: ${plan.color}12; border-radius: 20px; font-size: 0.875rem; color: var(--text); border: 1px solid ${plan.color}30;`}>
                        {plan.foodEmojis[i] && <span>{plan.foodEmojis[i]}</span>}
                        {food}
                      </span>
                    ))}
                  </div>
                </div>

                <!-- Benefits -->
                <div>
                  <h3 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 12px;">Proven Benefits</h3>
                  <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 7px;">
                    {plan.benefits.map(benefit => (
                      <li style="display: flex; align-items: flex-start; gap: 8px; font-size: 0.9rem; color: var(--text); line-height: 1.5;">
                        <span style={`color: ${plan.color}; font-weight: 700; flex-shrink: 0; margin-top: 1px;`}>✓</span>
                        {benefit}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Macro Breakdown -->
              <div style="background: var(--bg-section); border-radius: 12px; padding: 20px 24px; margin-bottom: 24px;">
                <h3 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 16px;">Typical Macro Breakdown</h3>
                <div style="display: flex; flex-wrap: wrap; gap: 12px;">
                  <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 18px; border-radius: 10px; border: 1px solid var(--border);">
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #EF476F; flex-shrink: 0;"></div>
                    <div>
                      <div style="font-size: 0.75rem; color: var(--text-muted);">Protein</div>
                      <div style="font-size: 1rem; font-weight: 700; color: var(--text);">{plan.macros.protein}</div>
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 18px; border-radius: 10px; border: 1px solid var(--border);">
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #F9C74F; flex-shrink: 0;"></div>
                    <div>
                      <div style="font-size: 0.75rem; color: var(--text-muted);">Carbohydrates</div>
                      <div style="font-size: 1rem; font-weight: 700; color: var(--text);">{plan.macros.carbs}</div>
                    </div>
                  </div>
                  <div style="display: flex; align-items: center; gap: 10px; background: white; padding: 10px 18px; border-radius: 10px; border: 1px solid var(--border);">
                    <div style="width: 12px; height: 12px; border-radius: 50%; background: #06D6A0; flex-shrink: 0;"></div>
                    <div>
                      <div style="font-size: 0.75rem; color: var(--text-muted);">Fat</div>
                      <div style="font-size: 1rem; font-weight: 700; color: var(--text);">{plan.macros.fat}</div>
                    </div>
                  </div>
                </div>
              </div>

              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-bottom: 24px;">

                <!-- Nutrient Strengths -->
                <div>
                  <h3 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--primary-dark); margin-bottom: 10px;">🌟 Nutrient Strengths</h3>
                  <div style="display: flex; flex-wrap: wrap; gap: 7px;">
                    {plan.nutrientStrengths.map(n => (
                      <span style="display: inline-block; padding: 4px 11px; background: #E8F8F0; border-radius: 20px; font-size: 0.8rem; color: var(--primary-dark); font-weight: 600; border: 1px solid rgba(46,204,113,0.25);">{n}</span>
                    ))}
                  </div>
                </div>

                <!-- Watch Out For -->
                <div>
                  <h3 style="font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-orange); margin-bottom: 10px;">⚠️ Watch Out For</h3>
                  <div style="display: flex; flex-direction: column; gap: 6px;">
                    {plan.potentialGaps.map(gap => (
                      <div style="display: flex; align-items: flex-start; gap: 8px; font-size: 0.875rem; color: var(--text);">
                        <span style="color: var(--accent-orange); flex-shrink: 0; font-weight: 700;">!</span>
                        {gap}
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <!-- Best For / Avoid -->
              <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; padding-top: 20px; border-top: 1px solid var(--border);">
                <div style="background: #F0FFF8; border-radius: 10px; padding: 16px 20px; border: 1px solid rgba(46,204,113,0.2);">
                  <div style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--primary-dark); margin-bottom: 6px;">👤 Who This Is For</div>
                  <p style="font-size: 0.9rem; color: var(--text); margin: 0; line-height: 1.6;">{plan.forWho}</p>
                </div>
                <div style="background: #FFF9F0; border-radius: 10px; padding: 16px 20px; border: 1px solid rgba(255,140,66,0.2);">
                  <div style="font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent-orange); margin-bottom: 6px;">🚫 Minimize / Avoid</div>
                  <p style="font-size: 0.9rem; color: var(--text); margin: 0; line-height: 1.6;">{plan.restricted}</p>
                </div>
              </div>

            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-alt" style="padding: 60px 20px;">
    <div class="container">
      <div class="section-header" style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; color: var(--text);">Diet Plan Comparison</h2>
        <p style="color: var(--text-muted); margin-top: 10px; font-size: 1rem;">How the 5 plans stack up across key dimensions</p>
      </div>
      <div style="overflow-x: auto; border-radius: var(--radius); box-shadow: var(--shadow);">
        <table style="width: 100%; border-collapse: collapse; background: white; min-width: 640px;">
          <thead>
            <tr style="background: var(--bg-section);">
              <th style="text-align: left; padding: 14px 20px; font-size: 0.85rem; color: var(--text-muted); font-weight: 700; border-bottom: 2px solid var(--border); min-width: 160px;">Feature</th>
              {dietPlans.map(plan => (
                <th style={`text-align: center; padding: 14px 16px; font-size: 0.85rem; color: var(--text); font-weight: 700; border-bottom: 2px solid ${plan.color}; min-width: 120px;`}>
                  <div>{plan.emoji}</div>
                  <div style="margin-top: 4px;">{plan.name.split(' ')[0]}</div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {[
              { label: 'Animal Products', values: ['Limited', 'Minimal/None', 'Limited', 'Moderate', 'Very limited'] },
              { label: 'Grain Emphasis', values: ['Whole grains', 'Whole grains', 'Whole grains', 'All grains', 'Ancient grains'] },
              { label: 'Legumes', values: ['Moderate', 'High', 'High', 'Moderate', 'Daily — essential'] },
              { label: 'Saturated Fat', values: ['Low', 'Very Low', 'Low', 'Moderate', 'Very Low'] },
              { label: 'Fiber Intake', values: ['High', 'Very High', 'High', 'Moderate-High', 'High'] },
              { label: 'Difficulty', values: ['Easy', 'Moderate', 'Easy', 'Easy', 'Easy'] },
              { label: 'Flexibility', values: ['★★★★★', '★★☆☆☆', '★★★★☆', '★★★★★', '★★★★☆'] },
              { label: 'Supplements Needed', values: ['Vit D', 'B12, Vit D, DHA', 'Vit D', 'Usually none', 'B12, Vit D'] },
            ].map((row, ri) => (
              <tr style={ri % 2 === 0 ? 'background: white;' : 'background: var(--bg-section);'}>
                <td style="padding: 14px 20px; font-size: 0.9rem; font-weight: 600; color: var(--text); border-right: 1px solid var(--border);">{row.label}</td>
                {row.values.map(val => (
                  <td style="padding: 14px 16px; text-align: center; font-size: 0.875rem; color: var(--text-muted);">{val}</td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Universal Rules -->
  <section class="section" style="padding: 60px 20px;">
    <div class="container">
      <div class="section-header" style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; color: var(--text);">What All Healthy Diets Agree On</h2>
        <p style="color: var(--text-muted); margin-top: 10px; font-size: 1rem; max-width: 560px; margin-left: auto; margin-right: auto;">Across every evidence-based dietary pattern, these principles consistently emerge as universal pillars of good health.</p>
      </div>
      <div class="grid-3" style="gap: 20px;">
        {[
          { emoji: '🥦', title: 'Eat Plenty of Vegetables', desc: 'Especially dark leafy greens daily. Aim for 5-9 servings. Diversity matters — try 30+ different plants per week for gut health.' },
          { emoji: '🚫', title: 'Minimize Ultra-Processed Foods', desc: 'If it has more than 5 ingredients you can\'t pronounce, it\'s probably ultra-processed. These are linked to virtually every chronic disease.' },
          { emoji: '💧', title: 'Stay Hydrated', desc: 'Water is the best beverage. Herbal teas and black coffee are fine. Minimize sugary drinks, sodas, and fruit juices.' },
          { emoji: '🌈', title: 'Eat Diverse Foods', desc: 'The more diverse your plant intake, the more diverse your gut microbiome. 30+ different plants per week is a research-backed target.' },
          { emoji: '🍬', title: 'Minimize Added Sugars', desc: 'Aim for under 25g (women) or 36g (men) added sugar daily. Natural sugars in whole fruits are fine — they come with fiber.' },
          { emoji: '🥑', title: 'Don\'t Fear Healthy Fats', desc: 'Olive oil, avocado, nuts, and seeds are all associated with better health outcomes. Fat is not the enemy — refined carbs and processed foods are.' },
          { emoji: '🥚', title: 'Eat Enough Protein', desc: 'Most adults need 0.8-1.6g per kg of body weight. Protein supports muscle, satiety, metabolism, and cellular repair.' },
          { emoji: '🦠', title: 'Include Fermented Foods', desc: 'Yogurt, kefir, kimchi, sauerkraut, miso, and tempeh all feed your gut microbiome. Even small amounts daily make a measurable difference.' },
        ].map(rule => (
          <div class="card" style="border-radius: var(--radius); padding: 24px; display: flex; flex-direction: column; gap: 10px;">
            <div style="font-size: 2rem;">{rule.emoji}</div>
            <h3 style="font-size: 1rem; font-weight: 700; color: var(--text); margin: 0;">{rule.title}</h3>
            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin: 0;">{rule.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section-alt" style="padding: 60px 20px;">
    <div class="container">
      <div style="max-width: 760px; margin: 0 auto;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.2rem); font-weight: 800; color: var(--text); margin-bottom: 36px; text-align: center;">Frequently Asked Questions</h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {[
            {
              q: 'Do I need supplements on any of these diets?',
              a: 'It depends on the plan. Whole-Food Plant-Based dieters MUST supplement Vitamin B12 and should consider Vitamin D, algae-based DHA/EPA, and iodine. Mediterranean and Anti-Inflammatory diets typically only need Vitamin D (as most people are deficient regardless of diet). Balanced Omnivores eating oily fish and eggs regularly can usually cover all bases from food alone. Longevity/Blue Zones followers often benefit from B12 as they age. When in doubt, get bloodwork done annually.'
            },
            {
              q: 'How do I transition to a healthier diet without feeling overwhelmed?',
              a: 'Start with addition, not subtraction. Add one serving of vegetables to each meal for two weeks. Then add a weekly legume dish. Then crowd out processed foods naturally as your preferences shift. Research shows that taste preferences change within 2-3 months of eating whole foods — what once seemed bland becomes delicious as your palate adapts. Don\'t aim for perfection. The 80/20 rule works well: eat according to your chosen pattern 80% of the time.'
            },
            {
              q: 'What about calories — do I need to count them?',
              a: 'Most people do not need to count calories if they follow any of these whole-food-based diets. Whole foods are naturally more satiating (due to fiber, water, and protein), and hunger signals become more reliable when you stop eating ultra-processed foods. However, if you have specific weight loss or muscle-building goals, tracking protein intake (and roughly total calories) for 4-6 weeks can be illuminating. Use it as a learning tool, not a permanent habit.'
            },
            {
              q: 'Can I combine elements from multiple plans?',
              a: 'Absolutely — and this is actually how most people eat in practice. The Mediterranean Diet and Anti-Inflammatory Diet overlap substantially. You might eat plant-based 5 days a week and Balanced Omnivore on weekends. The underlying principles (whole foods, diverse vegetables, limiting processed foods) are consistent across all plans. The specific "plan" is just a framework for thinking — not a rigid rulebook. What matters is long-term consistency with good food choices.'
            },
            {
              q: 'Which diet is best for weight loss specifically?',
              a: 'No single diet wins for weight loss — adherence does. Studies consistently show that people lose similar amounts of weight on low-carb vs. low-fat diets at 12-24 months. The key variables are: total calorie intake, protein (supports satiety and muscle), fiber (slows digestion and reduces hunger), and how sustainable the approach feels. All 5 plans here support healthy weight management when followed consistently. Choose the one that fits your food preferences and lifestyle.'
            },
          ].map(faq => (
            <details style="background: white; border-radius: 12px; border: 1px solid var(--border); overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04);">
              <summary style="padding: 20px 24px; font-size: 1rem; font-weight: 600; color: var(--text); cursor: pointer; display: flex; align-items: center; justify-content: space-between; list-style: none; gap: 16px;">
                <span>{faq.q}</span>
                <span style="color: var(--primary); font-size: 1.4rem; flex-shrink: 0; transition: transform 0.2s;">▾</span>
              </summary>
              <div style="padding: 0 24px 20px; color: var(--text-muted); line-height: 1.75; font-size: 0.95rem; border-top: 1px solid var(--border);">
                <p style="margin: 16px 0 0;">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding: 60px 20px; text-align: center; background: linear-gradient(135deg, #E8F8F0 0%, #F0F8FF 100%);">
    <div class="container">
      <div style="max-width: 560px; margin: 0 auto;">
        <div style="font-size: 2.5rem; margin-bottom: 16px;">🍽️</div>
        <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--text); margin-bottom: 12px;">Ready to Cook?</h2>
        <p style="color: var(--text-muted); margin-bottom: 28px; line-height: 1.7;">Browse our 12 global recipes — each with full micronutrient breakdowns — designed to match these diet plans.</p>
        <a href={`${base}recipes`} class="btn btn-primary" style="display: inline-flex; align-items: center; gap: 8px; padding: 14px 32px; font-size: 1rem; text-decoration: none; border-radius: 40px;">
          🌍 Explore World Recipes →
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  details[open] summary span:last-child {
    transform: rotate(180deg);
  }
  details summary::-webkit-details-marker {
    display: none;
  }
  @media (max-width: 640px) {
    .grid-3 {
      grid-template-columns: 1fr !important;
    }
  }
</style>
